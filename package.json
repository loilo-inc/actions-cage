{
  "name": "actions-cage",
  "private": true,
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "src/setup",
    "src/deploy",
    "src/audit",
    "src/util"
  ],
  "scripts": {
    "fmt": "prettier --write '**/*.ts'",
    "fmtcheck": "prettier --check '**/*.ts'",
    "test": "vitest run",
    "build": "make build",
    "clean": "make clean",
    "testci": "vitest run --coverage --coverage.provider=v8 --coverage.reporter=json --coverage.reportsDirectory=coverage"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@types/semver": "^7.5.8",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.4",
    "prettier": "^3",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.16"
  }
}
